connected_mode() {
  step "Connect to TranzFer server"
  local url=$(ask "Server URL" "http://localhost:8080")

  # Test connectivity
  local health=$(curl -s --max-time 5 "${url}/actuator/health" 2>/dev/null)
  if [ -z "$health" ]; then
    # Try via gateway on port 80
    health=$(curl -s --max-time 5 "http://$(echo $url | sed 's|http://||;s|:.*||'):80/health" 2>/dev/null)
    if echo "$health" | grep -q "UP"; then
      url="http://$(echo $url | sed 's|http://||;s|:.*||'):80"
      ok "Connected via API Gateway: $url"
    else
      fail "Cannot reach server at $url"
      info "Is the server running? Try: ./tranzfer doctor"
      return 1
    fi
  else
    ok "Server reachable"
  fi

  # Login
  if ! do_login "$url"; then return 1; fi

  # Route to role-appropriate menu
  case "$AUTH_ROLE" in
    ADMIN)        admin_menu ;;
    SERVER_ADMIN) server_admin_menu ;;
    *)            client_menu ;; # USER and any other role
  esac
}

# =============================================================================
# MAIN MENU
# =============================================================================

main_menu() {
  print_banner
  echo "  What would you like to do?"
  echo ""
  echo "    ${BOLD}Setup${NC}"
  echo "    1) Install Server"
  echo "    2) Install Client"
  echo ""
  echo "    ${BOLD}Connect${NC}"
  echo "    3) Login to server (role-based console)"
  echo ""
  echo ""
  echo "    ${BOLD}Migration${NC}"
  echo "    4) Migrate from existing MFT"
  echo "    ${BOLD}Operations${NC}"
  echo "    5) Health Check (Doctor)"
  echo "    6) Quick Status"
  echo "    7) Run Test Suite"
  echo ""
  echo "    8) Exit"
  echo ""
  local choice=$(ask "Select" "3")

  case $choice in
    1) install_server ;;
    2) install_client ;;
    3) connected_mode ;;
    4) bash "$(dirname "$0")/migration/migrate.sh" ;;
    5) run_doctor ;;
    6) run_status ;;
    7) [ -f "./tests/run-tests.sh" ] && ./tests/run-tests.sh --html || echo "Test suite not found." ;;
    8) echo "  Bye!"; exit 0 ;;
    *) echo "  Invalid choice"; main_menu ;;
  esac
}

# === Entry point ===
case "${1:-}" in
  install)
    case "${2:-}" in
      server) install_server ;;
      client) install_client ;;
      *) echo "Usage: $0 install [server|client]"; exit 1 ;;
    esac ;;
  login|connect) connected_mode ;;
  migrate) shift; bash "$(dirname "$0")/migration/migrate.sh" "$@" ;;
  doctor|diagnose|check) run_doctor ;;
  status) run_status ;;
  test) [ -f "./tests/run-tests.sh" ] && ./tests/run-tests.sh --html || echo "Test suite not found." ;;
  help|--help|-h)
    echo "Usage: tranzfer [command]"
    echo ""
    echo "Commands:"
    echo "  install server   Install TranzFer MFT server"
    echo "  install client   Install MFT client for file transfers"
    echo "  login            Login to server (role-based console)"
    echo "  migrate          Migrate users from existing MFT product"
    echo "  doctor           Diagnose and fix issues"
    echo "  status           Quick status check"
    echo "  test             Run full test suite"
    echo "  help             Show this help"
    echo ""
    echo "Migration sources:"
    echo "  migrate --source ssh       From OpenSSH SFTP"
    echo "  migrate --source ftp       From vsftpd/ProFTPD"
    echo "  migrate --source sterling  From IBM Sterling"
    echo "  migrate --import-csv f.csv From CSV file"
    echo ""
    echo "Roles:"
    echo "  ADMIN            Full access: users, config, AI, screening, infra"
    echo "  SERVER_ADMIN     Operations: transfers, accounts, flows, health"
    echo "  CLIENT (USER)    View own transfers, track files, see peers"
    ;;
  "") main_menu ;;
  *) echo "Unknown command: $1. Run 'tranzfer help' for usage."; exit 1 ;;
esac
