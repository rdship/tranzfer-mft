# Match natural language to a menu number. Returns the number or "?" if unknown.
# Tries local pattern matching first, falls back to AI engine if available.
nlp_match() {
  local input="$1" role="$2"
  local lower=$(echo "$input" | tr '[:upper:]' '[:lower:]')

  # If it's already a number, return it
  if [[ "$input" =~ ^[0-9]+$ ]]; then echo "$input"; return; fi

  # If it starts with !, pass through as raw CLI command
  if [[ "$input" == "!"* ]]; then echo "CLI:${input:1}"; return; fi

  # Track ID detection (12 alphanum chars starting with prefix)
  if [[ "$input" =~ [A-Z0-9]{12} ]]; then
    local tid=$(echo "$input" | grep -oE '[A-Z0-9]{12}')
    echo "TRACK:$tid"; return
  fi

  # --- Pattern matching by intent ---

  # Account/user queries
  if echo "$lower" | grep -qE "my account|my profile|who am i|account info"; then echo "1"; return; fi
  if echo "$lower" | grep -qE "list account|show account|all account|accounts"; then
    [ "$role" = "ADMIN" ] && echo "5" || echo "4"
    return
  fi
  if echo "$lower" | grep -qE "list user|show user|all user|users"; then echo "4"; return; fi
  if echo "$lower" | grep -qE "onboard|create user|new user|add user|register"; then echo "6"; return; fi
  if echo "$lower" | grep -qE "promote|demote|change role|make admin"; then echo "7"; return; fi

  # Transfer queries
  if echo "$lower" | grep -qE "track|trace|lookup|find transfer|where.s my file"; then echo "TRACK_ASK"; return; fi
  if echo "$lower" | grep -qE "recent transfer|latest transfer|last transfer|transfer history|my transfer"; then
    [ "$role" = "USER" ] && echo "2" || echo "2"
    return
  fi
  if echo "$lower" | grep -qE "fail|error|problem|broken|stuck|issue"; then echo "3"; return; fi
  if echo "$lower" | grep -qE "journey|lifecycle|what happened"; then echo "1"; return; fi

  # Flow queries
  if echo "$lower" | grep -qE "flow|pipeline|processing"; then
    [ "$role" = "ADMIN" ] && echo "8" || echo "5"
    return
  fi
  if echo "$lower" | grep -qE "mapping|routing|folder"; then echo "6"; return; fi

  # Operations
  if echo "$lower" | grep -qE "health|status|service|running|up.*down"; then
    [ "$role" = "ADMIN" ] && echo "18" || echo "7"
    return
  fi
  if echo "$lower" | grep -qE "screen|ofac|sanction|aml|compliance"; then
    [ "$role" = "ADMIN" ] && echo "14" || echo "8"
    return
  fi
  if echo "$lower" | grep -qE "sla|breach|overdue|late|agreement"; then
    [ "$role" = "ADMIN" ] && echo "12" || echo "9"
    return
  fi
  if echo "$lower" | grep -qE "schedul|cron|timer|job|task"; then
    [ "$role" = "ADMIN" ] && echo "11" || echo "10"
    return
  fi
  if echo "$lower" | grep -qE "connector|servicenow|snow|slack|pagerduty|team|alert.*channel"; then echo "10"; return; fi
  if echo "$lower" | grep -qE "security.*profile|cipher|mac|kex|tls"; then echo "9"; return; fi

  # Intelligence
  if echo "$lower" | grep -qE "recommend|suggestion|advice|what should|improve|optimize"; then echo "13"; return; fi
  if echo "$lower" | grep -qE "ai|classif|anomal|intelligence|smart"; then echo "13"; return; fi
  if echo "$lower" | grep -qE "key|cert|keystore|certificate|pgp|ssh.*key|rotate"; then echo "15"; return; fi
  if echo "$lower" | grep -qE "storage|disk|tier|hot|warm|cold|space|dedup"; then echo "16"; return; fi

  # System
  if echo "$lower" | grep -qE "overview|dashboard|summary|platform|stats"; then echo "17"; return; fi
  if echo "$lower" | grep -qE "terminal|shell|command|cli"; then echo "19"; return; fi
  if echo "$lower" | grep -qE "doctor|diagnose|fix|repair|check"; then echo "20"; return; fi
  if echo "$lower" | grep -qE "peer|p2p|online|who.s connected"; then echo "5"; return; fi
  if echo "$lower" | grep -qE "file|inbox|outbox|send|upload|download"; then echo "4"; return; fi

  # Logout/exit
  if echo "$lower" | grep -qE "logout|exit|quit|bye|leave"; then
    [ "$role" = "ADMIN" ] && echo "21" || ([ "$role" = "SERVER_ADMIN" ] && echo "12" || echo "6")
    return
  fi

  # Help
  if echo "$lower" | grep -qE "help|what can|command|menu|option"; then echo "HELP"; return; fi

  # Try AI engine if available
  if [ -n "$SERVER_URL" ]; then
    local ai_resp=$(curl -s --max-time 3 "${SERVER_URL}:8091/api/v1/ai/nlp/command" \
      -H "Content-Type: application/json" \
      -d "{\"query\":\"$input\"}" 2>/dev/null)
    local ai_cmd=$(echo "$ai_resp" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('command',''))" 2>/dev/null)
    if [ -n "$ai_cmd" ] && [ "$ai_cmd" != "None" ]; then
      echo "CLI:$ai_cmd"
      return
    fi
  fi

  echo "?"
}

# Smart prompt — accepts number or natural language
smart_prompt() {
  local role="$1"
  echo -ne "  ${CYAN}▸${NC} "
  read -r input
  if [ -z "$input" ]; then echo "HELP"; return; fi

  local result=$(nlp_match "$input" "$role")
  echo "$result"
}

# Execute a CLI command via server
run_cli_cmd() {
  local cmd="$1"
  api_call POST "/api/cli/execute" "{\"command\":\"$cmd\"}" | python3 -c "import sys,json; print(json.load(sys.stdin).get('output',''))" 2>/dev/null
}

