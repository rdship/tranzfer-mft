# Copy this file to .env and fill in your values

# Database
DATABASE_URL=jdbc:postgresql://localhost:5432/filetransfer
DB_USERNAME=postgres
DB_PASSWORD=postgres

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# JWT (generate a 256-bit random secret for production)
JWT_SECRET=change_me_in_production_256bit_secret_key_here!!

# Internal control API shared secret
CONTROL_API_KEY=internal_control_secret

# FTP passive mode public IP (your server's public IP)
FTP_PUBLIC_HOST=127.0.0.1

# Cluster identity (change per cluster deployment)
CLUSTER_ID=cluster-a

# Internal API security key (same across all services in a deployment)
CONTROL_API_KEY=internal_control_secret
