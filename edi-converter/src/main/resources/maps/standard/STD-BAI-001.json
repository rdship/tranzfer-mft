{
  "mapId": "STD-BAI-001",
  "name": "BAI2 Bank Statement to Internal Bank Statement",
  "version": "1.0.0",
  "sourceType": "BAI2_STATEMENT",
  "targetType": "BANK_STATEMENT_INH",
  "sourceStandard": "BAI2",
  "targetStandard": "INHOUSE",
  "bidirectional": false,
  "description": "Standard map for converting BAI2 (Balance and Activity Information) bank statement to TranzFer internal format. Maps 01 file header, 02 group header, 03 account records, and 16 transaction detail records.",
  "status": "ACTIVE",
  "confidence": 1.0,
  "fieldMappings": [
    {"sourcePath": "01.01", "targetPath": "fileId", "transform": "TRIM", "confidence": 1.0},
    {"sourcePath": "01.02", "targetPath": "senderId", "transform": "TRIM", "required": true, "confidence": 1.0},
    {"sourcePath": "01.03", "targetPath": "receiverId", "transform": "TRIM", "required": true, "confidence": 1.0},
    {"sourcePath": "01.04", "targetPath": "fileCreationDate", "transform": "DATE_FORMAT", "transformConfig": {"sourceFormat": "yyMMdd", "targetFormat": "yyyy-MM-dd"}, "confidence": 1.0},
    {"sourcePath": "01.05", "targetPath": "fileCreationTime", "transform": "COPY", "confidence": 0.9},
    {"sourcePath": "01.06", "targetPath": "fileIdentificationNumber", "transform": "TRIM", "confidence": 0.9},
    {"sourcePath": "02.01", "targetPath": "group.ultimateReceiverId", "transform": "TRIM", "confidence": 1.0},
    {"sourcePath": "02.02", "targetPath": "group.originatorId", "transform": "TRIM", "confidence": 1.0},
    {"sourcePath": "02.03", "targetPath": "group.status", "transform": "LOOKUP", "transformConfig": {"table": "groupStatusCodes"}, "confidence": 1.0},
    {"sourcePath": "02.04", "targetPath": "group.asOfDate", "transform": "DATE_FORMAT", "transformConfig": {"sourceFormat": "yyMMdd", "targetFormat": "yyyy-MM-dd"}, "confidence": 1.0},
    {"sourcePath": "02.05", "targetPath": "group.asOfTime", "transform": "COPY", "confidence": 0.9},
    {"sourcePath": "02.06", "targetPath": "group.currencyCode", "transform": "COPY", "defaultValue": "USD", "confidence": 1.0},
    {"sourcePath": "03.01", "targetPath": "account.accountNumber", "transform": "TRIM", "required": true, "confidence": 1.0},
    {"sourcePath": "03.02", "targetPath": "account.currencyCode", "transform": "COPY", "defaultValue": "USD", "confidence": 1.0},
    {"sourcePath": "03.03", "targetPath": "account.summaryTypeCode", "transform": "LOOKUP", "transformConfig": {"table": "summaryTypeCodes"}, "confidence": 1.0},
    {"sourcePath": "03.04", "targetPath": "account.summaryAmount", "transform": "COPY", "confidence": 1.0},
    {"sourcePath": "03.05", "targetPath": "account.summaryItemCount", "transform": "COPY", "confidence": 0.9},
    {"sourcePath": "03.06", "targetPath": "account.fundsType", "transform": "LOOKUP", "transformConfig": {"table": "fundsTypeCodes"}, "confidence": 0.9},
    {"sourcePath": "49.01", "targetPath": "fileControlTotal", "transform": "COPY", "confidence": 1.0},
    {"sourcePath": "49.02", "targetPath": "fileNumberOfGroups", "transform": "COPY", "confidence": 1.0},
    {"sourcePath": "49.03", "targetPath": "fileNumberOfRecords", "transform": "COPY", "confidence": 1.0}
  ],
  "loopMappings": [
    {
      "sourceLoop": "16",
      "targetArray": "transactions",
      "fieldMappings": [
        {"sourcePath": "16.01", "targetPath": "typeCode", "transform": "LOOKUP", "transformConfig": {"table": "transactionTypeCodes"}, "required": true, "confidence": 1.0},
        {"sourcePath": "16.02", "targetPath": "amount", "transform": "COPY", "required": true, "confidence": 1.0},
        {"sourcePath": "16.03", "targetPath": "fundsType", "transform": "LOOKUP", "transformConfig": {"table": "fundsTypeCodes"}, "confidence": 0.9},
        {"sourcePath": "16.04", "targetPath": "bankReferenceNumber", "transform": "TRIM", "confidence": 1.0},
        {"sourcePath": "16.05", "targetPath": "customerReferenceNumber", "transform": "TRIM", "confidence": 1.0},
        {"sourcePath": "16.06", "targetPath": "text", "transform": "TRIM", "confidence": 0.9}
      ]
    },
    {
      "sourceLoop": "88",
      "targetArray": "continuationRecords",
      "fieldMappings": [
        {"sourcePath": "88.01", "targetPath": "continuationText", "transform": "TRIM", "confidence": 0.9}
      ]
    }
  ],
  "codeTables": {
    "groupStatusCodes": [
      {"sourceCode": "1", "targetCode": "UPDATE", "description": "Update (this is the most common)"},
      {"sourceCode": "2", "targetCode": "DELETION", "description": "Deletion"},
      {"sourceCode": "3", "targetCode": "CORRECTION", "description": "Correction"},
      {"sourceCode": "4", "targetCode": "TEST_ONLY", "description": "Test only"}
    ],
    "summaryTypeCodes": [
      {"sourceCode": "010", "targetCode": "OPENING_LEDGER", "description": "Opening ledger balance"},
      {"sourceCode": "015", "targetCode": "CLOSING_LEDGER", "description": "Closing ledger balance"},
      {"sourceCode": "040", "targetCode": "OPENING_AVAILABLE", "description": "Opening available balance"},
      {"sourceCode": "045", "targetCode": "CLOSING_AVAILABLE", "description": "Closing available balance"},
      {"sourceCode": "100", "targetCode": "TOTAL_CREDITS", "description": "Total credits"},
      {"sourceCode": "400", "targetCode": "TOTAL_DEBITS", "description": "Total debits"}
    ],
    "fundsTypeCodes": [
      {"sourceCode": "0", "targetCode": "IMMEDIATE", "description": "Immediately available (same day)"},
      {"sourceCode": "1", "targetCode": "ONE_DAY", "description": "One-day availability"},
      {"sourceCode": "2", "targetCode": "TWO_DAY", "description": "Two or more days availability"},
      {"sourceCode": "S", "targetCode": "DISTRIBUTED", "description": "Distributed availability"},
      {"sourceCode": "V", "targetCode": "VALUE_DATE", "description": "Value date"},
      {"sourceCode": "Z", "targetCode": "UNKNOWN", "description": "Unknown"}
    ],
    "transactionTypeCodes": [
      {"sourceCode": "108", "targetCode": "CREDIT_ACH", "description": "ACH credit received"},
      {"sourceCode": "115", "targetCode": "CREDIT_LOCKBOX", "description": "Lockbox deposit"},
      {"sourceCode": "142", "targetCode": "CREDIT_COLLECTION", "description": "Collection item"},
      {"sourceCode": "165", "targetCode": "CREDIT_PREAUTH", "description": "Preauthorized ACH credit"},
      {"sourceCode": "175", "targetCode": "CREDIT_CHECK_DEPOSIT", "description": "Check deposit"},
      {"sourceCode": "195", "targetCode": "CREDIT_INCOMING_WIRE", "description": "Incoming wire transfer"},
      {"sourceCode": "275", "targetCode": "CREDIT_OTHER", "description": "Other credit"},
      {"sourceCode": "301", "targetCode": "CREDIT_INVESTMENT_SOLD", "description": "Investment securities sold"},
      {"sourceCode": "408", "targetCode": "DEBIT_ACH", "description": "ACH debit"},
      {"sourceCode": "451", "targetCode": "DEBIT_DRAFT", "description": "Draft/check paid"},
      {"sourceCode": "455", "targetCode": "DEBIT_PREAUTH", "description": "Preauthorized ACH debit"},
      {"sourceCode": "495", "targetCode": "DEBIT_OUTGOING_WIRE", "description": "Outgoing wire transfer"},
      {"sourceCode": "501", "targetCode": "DEBIT_INVESTMENT_PURCHASED", "description": "Investment securities purchased"},
      {"sourceCode": "555", "targetCode": "DEBIT_OTHER", "description": "Other debit"},
      {"sourceCode": "698", "targetCode": "FEE_MISC", "description": "Miscellaneous fee"},
      {"sourceCode": "890", "targetCode": "FLOAT_ADJUSTMENT", "description": "Float adjustment"}
    ]
  }
}
